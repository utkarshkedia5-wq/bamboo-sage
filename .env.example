# ─── Bamboo AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your real values.

# ── AI KEYS ──────────────────────────────────────────────────────────────────

# Claude (Anthropic) — console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# Sarvam AI — sarvam.ai → Dashboard → API Keys (best for Hindi/Telugu/regional)
SARVAM_API_KEY=your-sarvam-key-here

# Screenshot service — screenshotone.com (100 free/month, great for demos)
# Leave blank to use thum.io free fallback (no key needed, slightly slower)
SCREENSHOT_API_KEY=

# ── EMAIL ────────────────────────────────────────────────────────────────────

# Gmail App Password (NOT your normal Gmail password)
# Gmail → Manage Account → Security → 2-Step Verification → App Passwords
# Create one called "SAGE" and paste the 16-char password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Your name as it appears in outreach emails (keep SAGE branding)
FROM_NAME=Rohan from SAGE

# ── URLS ─────────────────────────────────────────────────────────────────────

# Where your demo HTML files are hosted (deploy output/ to Vercel or Render)
# Free Vercel deploy: vercel.com → New Project → upload output folder
DEMO_BASE_URL=https://demos.bamboo-ai.in

# Your Calendly scheduling link
CALENDLY_URL=https://calendly.com/your-link/30min

# Where server.py is running (Railway / Render free tier works fine)
BACKEND_URL=https://api.bamboo-ai.in
